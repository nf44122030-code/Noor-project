<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Intellix</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>intellix_clean</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>

	<!-- ── Portrait only ─────────────────────────────────────────────────── -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
	</array>

	<!-- ── Camera & Microphone (video sessions) ──────────────────────────── -->
	<key>NSCameraUsageDescription</key>
	<string>Intellix needs camera access to start video sessions with experts.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Intellix needs microphone access so you can speak during expert sessions, enable AI note-taking, and use voice input with the AI assistant.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Intellix uses speech recognition so you can dictate messages to the AI assistant hands-free.</string>

	<!-- ── Notifications ─────────────────────────────────────────────────── -->
	<key>NSUserNotificationsUsageDescription</key>
	<string>Intellix sends notifications to remind you about upcoming sessions and important updates.</string>

	<!-- ── Photo Library (if user uploads a profile picture) ────────────── -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Intellix needs photo library access so you can set your profile picture.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Intellix needs permission to save images to your photo library.</string>

	<!-- ── Local Network (Firebase / LAN connections) ────────────────────── -->
	<key>NSLocalNetworkUsageDescription</key>
	<string>Intellix uses the local network to communicate with Firebase services.</string>

	<!-- ── Performance & UI tweaks ───────────────────────────────────────── -->
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
</dict>
</plist>
